{
  "name": "my-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "cf:dev": "pnpm build && wrangler pages dev ./dist",
    "cf:deploy": "pnpm build && wrangler pages deploy ./dist",
    "cf:deploy:prod": "pnpm cf:deploy -- --branch main",
    "astro": "astro",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@analogjs/astro-angular": "^2.3.1",
    "@andersseen/icon": "^0.0.1",
    "@andersseen/web-components": "^0.0.2",
    "@angular/animations": "^21.2.4",
    "@angular/build": "^21.2.2",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/compiler-cli": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/language-service": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-server": "^21.2.4",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.4",
    "dexie": "^4.3.0",
    "nanostores": "^1.2.0",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  }
}
