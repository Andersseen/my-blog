---
import type { HTMLAttributes } from 'astro/types';
import { stripLocaleFromPath } from '../i18n';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = stripLocaleFromPath(Astro.url.pathname.replace(import.meta.env.BASE_URL, ''));
const hrefPath = typeof href === 'string' ? href : href?.pathname ?? '/';
const targetPath = stripLocaleFromPath(hrefPath);
const subpath = pathname.match(/[^\/]+/g);
const isActive = targetPath === pathname || targetPath === '/' + (subpath?.[0] || '');

const baseClasses =
	'rounded-md px-2 py-1.5 sm:px-3 sm:py-2 text-sm font-medium text-foreground/80 transition hover:bg-primary-100 hover:text-primary-800';
const activeClasses = 'bg-primary-100 text-primary-900';
---

<a href={href} class:list={[baseClasses, className, isActive && activeClasses]} {...props}>
	<slot />
</a>
