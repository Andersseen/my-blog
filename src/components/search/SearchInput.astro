---
import type { Dictionary } from '../../i18n';

interface Props {
  messages: Dictionary;
}

const { messages } = Astro.props;
---

<div class="relative" data-pagefind-search>
  <label for="search-input" class="sr-only">{messages.nav.search || 'Buscar'}</label>
  <div class="relative">
    <svg
      class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"
      />
    </svg>
    <input
      id="search-input"
      type="search"
      placeholder={messages.nav.searchPlaceholder || 'Buscar articulos...'}
      class="w-full rounded-full border border-primary-300 bg-surface-strong py-2 pl-10 pr-4 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
      data-pagefind-ui
    />
  </div>
</div>

<script>
  async function loadPagefindScript() {
    return new Promise((resolve, reject) => {
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind.js';
      script.onload = () => resolve(window.pagefind);
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  async function initPagefind() {
    const searchInput = document.querySelector('[data-pagefind-ui]');
    if (!searchInput || typeof window === 'undefined') return;

    searchInput.addEventListener('focus', async () => {
      if (window.__pagefindLoaded) return;
      try {
        const pagefind = await loadPagefindScript();
        if (!pagefind) {
          console.warn('Pagefind not available');
          return;
        }
        await pagefind.init();
        window.__pagefindLoaded = true;

        searchInput.addEventListener('input', async (e) => {
          const target = e.target;
          const query = target.value;
          if (query.length < 2) return;

          const results = await pagefind.search(query);
          console.log('Pagefind results:', results);
        });
      } catch (err) {
        console.warn('Pagefind not available:', err);
      }
    }, { once: true });
  }

  void initPagefind();
</script>
