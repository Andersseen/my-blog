---
import type { Dictionary, Locale } from '../i18n';

interface Props {
  messages: Dictionary;
}

const { messages } = Astro.props;
---

<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:absolute focus:z-[9999] focus:top-4 focus:left-4 focus:px-4 focus:py-2 focus:bg-primary-600 focus:text-white focus:rounded-lg focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-600 transition-all"
>
  {messages.nav.skipToContent || 'Saltar al contenido principal'}
</a>
