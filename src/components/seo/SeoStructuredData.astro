---
import {
  AUTHOR_GITHUB_URL,
  AUTHOR_MEDIUM_URL,
  AUTHOR_NAME,
  AUTHOR_PORTFOLIO_URL,
  SITE_TITLE,
  SITE_URL,
} from '../../consts';

interface Props {
  title: string;
  description: string;
  pageURL: string;
  imageURL: string;
  pageType?: 'website' | 'article';
}

const { title, description, pageURL, imageURL, pageType = 'website' } = Astro.props;

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE_URL}/#website`,
      url: SITE_URL,
      name: SITE_TITLE,
      description,
      inLanguage: 'es',
      publisher: {
        '@id': `${SITE_URL}/#person`,
      },
    },
    {
      '@type': 'Person',
      '@id': `${SITE_URL}/#person`,
      name: AUTHOR_NAME,
      url: AUTHOR_PORTFOLIO_URL,
      sameAs: [AUTHOR_PORTFOLIO_URL, AUTHOR_MEDIUM_URL, AUTHOR_GITHUB_URL],
    },
    {
      '@type': 'WebPage',
      '@id': `${pageURL}#webpage`,
      url: pageURL,
      name: title,
      description,
      isPartOf: {
        '@id': `${SITE_URL}/#website`,
      },
      about: {
        '@id': `${SITE_URL}/#person`,
      },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: imageURL,
      },
    },
    ...(pageType === 'article'
      ? [
          {
            '@type': 'BlogPosting',
            headline: title,
            description,
            image: imageURL,
            mainEntityOfPage: `${pageURL}#webpage`,
            author: {
              '@id': `${SITE_URL}/#person`,
            },
            publisher: {
              '@id': `${SITE_URL}/#person`,
            },
          },
        ]
      : []),
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
