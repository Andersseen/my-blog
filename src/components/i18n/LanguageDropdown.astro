---
import { LOCALES, type Dictionary, type Locale, toLocalePath } from '../../i18n';

interface Props {
  locale: Locale;
  messages: Dictionary;
  currentPath: string;
  class?: string;
  slot?: string;
}

const { locale, messages, currentPath, class: className, slot: slotName } = Astro.props;

const languageItems = LOCALES.filter((lang) => lang !== locale).map((lang) => ({
  text: messages.language[lang],
  value: toLocalePath(lang, currentPath),
}));

const activeLabel = messages.language[locale];
---

<and-dropdown
  slot={slotName}
  class:list={['language-dropdown w-auto min-w-[84px] sm:min-w-[88px]', className]}
  label={`${messages.language.label}: ${activeLabel}`}
  data-language-dropdown
  data-language-items={JSON.stringify(languageItems)}
  aria-label={messages.language.label}
>
  <button
    slot="trigger"
    type="button"
    data-language-trigger
    aria-expanded="false"
    aria-haspopup="menu"
    class="inline-flex h-10 w-full items-center justify-between rounded-md border border-primary-300 bg-[hsl(var(--surface-strong)/0.96)] px-2.5 text-xs font-semibold uppercase tracking-wide text-foreground shadow-sm transition hover:bg-primary-100"
  >
    <span class="inline-flex items-center gap-1.5 whitespace-nowrap">
      <and-icon name="compass" size="14" aria-hidden="true"></and-icon>
      {activeLabel}
    </span>
    <and-icon name="chevron-down" size="14" aria-hidden="true"></and-icon>
  </button>
</and-dropdown>

<script>
  type DropdownItem = {
    text: string;
    value: string;
    disabled?: boolean;
  };

  type AndDropdownElement = HTMLElement & {
    items: DropdownItem[];
  };

  const updateTriggerExpanded = (dropdown: HTMLElement, isOpen: boolean) => {
    const trigger = dropdown.querySelector<HTMLButtonElement>('[data-language-trigger]');

    if (!trigger) {
      return;
    }

    trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  };

  const parseItems = (rawItems: string | null): DropdownItem[] => {
    if (!rawItems) {
      return [];
    }

    try {
      const parsed = JSON.parse(rawItems) as DropdownItem[];
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  };

  const mountLanguageDropdowns = async () => {
    if (typeof customElements !== 'undefined') {
      await customElements.whenDefined('and-dropdown');
    }

    const dropdowns = document.querySelectorAll<AndDropdownElement>('[data-language-dropdown]');

    dropdowns.forEach((dropdown) => {
      if (dropdown.dataset.bound === 'true') {
        return;
      }

      dropdown.dataset.bound = 'true';
      dropdown.items = parseItems(dropdown.getAttribute('data-language-items'));

      updateTriggerExpanded(dropdown, false);

      dropdown.addEventListener('andDropdownOpenChange', (event: Event) => {
        const isOpen = (event as CustomEvent<boolean>).detail;
        updateTriggerExpanded(dropdown, Boolean(isOpen));
      });

      dropdown.addEventListener('andDropdownSelect', (event: Event) => {
        const selection = (event as CustomEvent<string>).detail;

        if (typeof selection !== 'string' || selection.length === 0) {
          return;
        }

        window.location.assign(selection);
      });
    });
  };

  void mountLanguageDropdowns();
</script>