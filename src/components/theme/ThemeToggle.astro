---
import type { Dictionary } from '../../i18n';

interface Props {
  class?: string;
  messages: Dictionary;
}

const { class: className, messages } = Astro.props;
---

<div
  data-theme-switcher
  data-theme-light={messages.theme.light}
  data-theme-dark={messages.theme.dark}
  class:list={[
    'inline-flex items-center gap-1.5 rounded-md border border-primary-300 bg-[hsl(var(--surface)/0.82)] px-1.5 py-1.5 text-xs font-semibold text-foreground sm:gap-2 sm:px-2',
    className,
  ]}
>
  <span class="sr-only">{messages.theme.aria}</span>
  <and-icon name="sun" size="14" aria-hidden="true" class="text-primary-700"></and-icon>

  <button
    type="button"
    role="switch"
    aria-checked="false"
    aria-label={messages.theme.aria}
    data-theme-switch
    class="relative h-8 w-12 rounded-full bg-primary-200 p-0.5 transition-colors sm:h-6 sm:w-11"
  >
    <span
      data-theme-thumb
      class="block h-5 w-5 rounded-full bg-[hsl(var(--surface))] shadow transition-transform duration-200"
    ></span>
  </button>

  <and-icon name="moon" size="14" aria-hidden="true" class="text-primary-900"></and-icon>
  <span data-theme-current class="hidden min-w-[44px] text-left uppercase tracking-wide text-[11px] sm:inline">{messages.theme.light}</span>
</div>

<script>
  import { $theme, initTheme, setTheme } from '../../store/theme';

  type Theme = 'light' | 'dark';

  const updateThemeSwitch = (wrapper: HTMLElement, theme: Theme) => {
    const switchButton = wrapper.querySelector<HTMLButtonElement>('[data-theme-switch]');
    const thumb = wrapper.querySelector<HTMLElement>('[data-theme-thumb]');
    const current = wrapper.querySelector<HTMLElement>('[data-theme-current]');

    if (!switchButton || !thumb) {
      return;
    }

    const isDark = theme === 'dark';
    const lightLabel = wrapper.dataset.themeLight ?? 'Light';
    const darkLabel = wrapper.dataset.themeDark ?? 'Dark';

    switchButton.setAttribute('aria-checked', isDark ? 'true' : 'false');
    switchButton.classList.toggle('bg-primary-600', isDark);
    switchButton.classList.toggle('bg-primary-200', !isDark);
    thumb.classList.toggle('translate-x-5', isDark);

    if (current) {
      current.textContent = isDark ? darkLabel : lightLabel;
    }
  };

  const mountThemeSwitchers = async () => {
    const wrappers = document.querySelectorAll<HTMLElement>('[data-theme-switcher]');

    if (wrappers.length === 0) {
      return;
    }

    const currentTheme = await initTheme();

    wrappers.forEach((wrapper) => {
      const switchButton = wrapper.querySelector<HTMLButtonElement>('[data-theme-switch]');

      if (!switchButton || wrapper.dataset.bound === 'true') {
        return;
      }

      wrapper.dataset.bound = 'true';
      updateThemeSwitch(wrapper, currentTheme);

      switchButton.addEventListener('click', async () => {
        const nextTheme: Theme = switchButton.getAttribute('aria-checked') === 'true' ? 'light' : 'dark';
        await setTheme(nextTheme);
      });

      const unsubscribe = $theme.listen((theme) => {
        updateThemeSwitch(wrapper, theme);
      });

      window.addEventListener(
        'beforeunload',
        () => {
          unsubscribe();
        },
        { once: true },
      );
    });
  };

  void mountThemeSwitchers();
</script>
