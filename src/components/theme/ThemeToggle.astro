---
import type { Dictionary } from '../../i18n';

interface Props {
  class?: string;
  messages: Dictionary;
  slot?: string;
}

const { class: className, messages, slot: slotName } = Astro.props;
---

<style>
  [data-theme-switcher] {
    --background: var(--surface-strong);
    --foreground: var(--foreground);
    --primary: var(--primary-600);
    --primary-foreground: 0 0% 100%;
    --secondary: var(--surface-container-high);
    --secondary-foreground: var(--foreground);
    --border: var(--primary-300);
    --input: var(--primary-300);
    --ring: var(--primary-500);
    --accent: var(--primary-100);
    --accent-foreground: var(--primary-900);
  }
</style>

<div
  slot={slotName}
  data-theme-switcher
  data-theme-aria={messages.theme.aria}
  data-theme-light={messages.theme.light}
  data-theme-dark={messages.theme.dark}
  class:list={[
    'inline-flex items-center',
    className,
  ]}
>
  <and-button
    type="button"
    variant="outline"
    size="icon"
    role="switch"
    aria-checked="false"
    aria-label={messages.theme.aria}
    data-theme-switch
    custom-class="h-10 w-10"
  >
    <span class="sr-only" data-theme-current>{messages.theme.light}</span>
    <and-icon data-theme-icon name="sun" size="16" aria-hidden="true"></and-icon>
  </and-button>
</div>

<script>
  import { $theme, initTheme, setTheme } from '../../store/theme';

  type Theme = 'light' | 'dark';

  const updateThemeSwitch = (wrapper: HTMLElement, theme: Theme) => {
    const switchButton = wrapper.querySelector<HTMLElement>('[data-theme-switch]');
    const icon = wrapper.querySelector<HTMLElement>('[data-theme-icon]');
    const current = wrapper.querySelector<HTMLElement>('[data-theme-current]');

    if (!switchButton || !icon) {
      return;
    }

    const isDark = theme === 'dark';
    const ariaLabel = wrapper.dataset.themeAria ?? 'Toggle theme';
    const lightLabel = wrapper.dataset.themeLight ?? 'Light';
    const darkLabel = wrapper.dataset.themeDark ?? 'Dark';
    const currentLabel = isDark ? darkLabel : lightLabel;

    switchButton.setAttribute('aria-checked', isDark ? 'true' : 'false');
    switchButton.setAttribute('aria-label', `${ariaLabel}: ${currentLabel}`);
    switchButton.setAttribute('title', currentLabel);

    icon.setAttribute('name', isDark ? 'moon' : 'sun');
    switchButton.setAttribute('variant', isDark ? 'secondary' : 'outline');

    if (current) {
      current.textContent = currentLabel;
    }
  };

  const mountThemeSwitchers = async () => {
    const wrappers = document.querySelectorAll<HTMLElement>('[data-theme-switcher]');

    if (wrappers.length === 0) {
      return;
    }

    const currentTheme = await initTheme();

    wrappers.forEach((wrapper) => {
      const switchButton = wrapper.querySelector<HTMLElement>('[data-theme-switch]');

      if (!switchButton || wrapper.dataset.bound === 'true') {
        return;
      }

      wrapper.dataset.bound = 'true';
      updateThemeSwitch(wrapper, currentTheme);

      switchButton.addEventListener('click', async () => {
        const nextTheme: Theme = switchButton.getAttribute('aria-checked') === 'true' ? 'light' : 'dark';
        await setTheme(nextTheme);
      });

      const unsubscribe = $theme.listen((theme) => {
        updateThemeSwitch(wrapper, theme);
      });

      window.addEventListener(
        'beforeunload',
        () => {
          unsubscribe();
        },
        { once: true },
      );
    });
  };

  void mountThemeSwitchers();
</script>
