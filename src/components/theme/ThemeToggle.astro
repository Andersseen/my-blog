---
import type { Dictionary } from '../../i18n';

interface Props {
  class?: string;
  messages: Dictionary;
}

const { class: className, messages } = Astro.props;
---

<button
  type="button"
  data-theme-toggle
  data-theme-label={messages.theme.label}
  data-theme-light={messages.theme.light}
  data-theme-dark={messages.theme.dark}
  class:list={[
    'inline-flex items-center rounded-md border border-primary-300 px-3 py-2 text-xs font-semibold uppercase tracking-wide text-foreground transition hover:bg-primary-100',
    className,
  ]}
  aria-label={messages.theme.aria}
>
  {messages.theme.label}: {messages.theme.light}
</button>

<script>
  import { $theme, initTheme, toggleTheme } from '../../store/theme';

  type Theme = 'light' | 'dark';

  const updateButtonLabel = (button: HTMLButtonElement, theme: Theme) => {
    const label = button.dataset.themeLabel ?? 'Theme';
    const lightLabel = button.dataset.themeLight ?? 'Light';
    const darkLabel = button.dataset.themeDark ?? 'Dark';
    button.textContent = `${label}: ${theme === 'dark' ? darkLabel : lightLabel}`;
  };

  const mountThemeToggle = async () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]');

    if (buttons.length === 0) {
      return;
    }

    const currentTheme = await initTheme();

    buttons.forEach((button) => {
      if (button.dataset.bound === 'true') {
        return;
      }

      button.dataset.bound = 'true';
      updateButtonLabel(button, currentTheme);

      button.addEventListener('click', async () => {
        const nextTheme = await toggleTheme();
        updateButtonLabel(button, nextTheme);
      });

      const unsubscribe = $theme.listen((theme) => {
        updateButtonLabel(button, theme);
      });

      window.addEventListener(
        'beforeunload',
        () => {
          unsubscribe();
        },
        { once: true },
      );
    });
  };

  void mountThemeToggle();
</script>
