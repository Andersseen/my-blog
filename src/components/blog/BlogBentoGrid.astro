---
import FormattedDate from '../FormattedDate.astro';
import { type Dictionary, type Locale, toLocalePath } from '../../i18n';

interface Props {
  posts: any[];
  locale: Locale;
  messages: Dictionary;
}

const { posts, locale, messages } = Astro.props;

/** Resolve the correct href for local vs external posts */
const postHref = (post: any) =>
  post.data.isExternal ? post.data.link : toLocalePath(locale, `/blog/${post.id}/`);

const isExt = (post: any) => !!post.data.isExternal;

const heroSrc = (post: any) =>
  typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage?.src;

/**
 * Bento layout pattern (repeats every 5 posts):
 *   Row A: featured (8 cols × 2 rows) + secondary (4 cols × 2 rows)
 *   Row B: 1-3 compact cards (4 cols each)
 */
const CHUNK_SIZE = 5;
const chunks: any[][] = [];
for (let i = 0; i < posts.length; i += CHUNK_SIZE) {
  chunks.push(posts.slice(i, i + CHUNK_SIZE));
}
---

<style>
  .bento-card {
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease;
  }

  .bento-card:hover {
    transform: translateY(-4px);
  }
</style>

{chunks.map((chunk, chunkIndex) => {
  const featured  = chunk[0];
  const secondary = chunk[1];
  const rest      = chunk.slice(2);

  return (
    <div class:list={["grid grid-cols-1 gap-5 md:grid-cols-12 md:auto-rows-[210px]", chunkIndex > 0 && "mt-5"]}>

      {/* ── Featured: 8 cols × 2 rows — full-bleed hero image ── */}
      {featured && (
        <a
          href={postHref(featured)}
          target={isExt(featured) ? "_blank" : undefined}
          rel={isExt(featured) ? "noopener noreferrer" : undefined}
          class="group block md:col-span-8 md:row-span-2"
        >
          <and-card variant="elevated" class="bento-card relative h-full overflow-hidden rounded-2xl">
            {heroSrc(featured) ? (
              <div class="absolute inset-0">
                <img
                  src={heroSrc(featured)}
                  alt={featured.data.title}
                  loading={chunkIndex === 0 ? 'eager' : 'lazy'}
                  decoding={chunkIndex === 0 ? 'sync' : 'async'}
                  class="h-full w-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--background)/0.96)] via-[hsl(var(--surface)/0.55)] to-[hsl(var(--surface)/0.15)]" />
              </div>
            ) : (
              <div class="absolute inset-0 -z-10">
                <div class="absolute -left-1/4 -top-1/4 h-3/4 w-3/4 rounded-full bg-primary-300/10 blur-3xl" />
                <div class="absolute -right-1/4 bottom-0 h-1/2 w-1/2 rounded-full bg-secondary/5 blur-3xl" />
              </div>
            )}

            <div class="relative z-10 flex h-full flex-col justify-end p-8 md:p-12">
              <div class="space-y-4">
                <div class="flex items-center gap-2">
                  {isExt(featured) && <and-badge variant="secondary" class="text-[9px] uppercase">Medium</and-badge>}
                  <and-badge variant="secondary" class="inline-block w-fit text-[10px] uppercase tracking-[0.15em]">
                    <FormattedDate date={featured.data.pubDate} />
                  </and-badge>
                </div>
                <h2 class="text-3xl font-bold leading-tight tracking-tight text-foreground transition-colors group-hover:text-primary-600 md:text-4xl">
                  {featured.data.title}
                </h2>
                <p class="line-clamp-2 max-w-xl text-muted-foreground">
                  {featured.data.description}
                </p>
              </div>
            </div>
          </and-card>
        </a>
      )}

      {/* ── Secondary: 4 cols × 2 rows — hero image with overlay ── */}
      {secondary && (
        <a
          href={postHref(secondary)}
          target={isExt(secondary) ? "_blank" : undefined}
          rel={isExt(secondary) ? "noopener noreferrer" : undefined}
          class="group block md:col-span-4 md:row-span-2"
        >
          <and-card variant="default" class="bento-card relative h-full overflow-hidden rounded-2xl">
            {heroSrc(secondary) ? (
              <div class="absolute inset-0">
                <img
                  src={heroSrc(secondary)}
                  alt={secondary.data.title}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--background)/0.94)] via-[hsl(var(--surface)/0.55)] to-[hsl(var(--surface)/0.2)]" />
              </div>
            ) : (
              <div class="absolute inset-0 -z-10">
                <div class="absolute -left-1/4 -top-1/4 h-3/4 w-3/4 rounded-full bg-primary-300/10 blur-3xl" />
              </div>
            )}

            <div class="relative z-10 flex h-full flex-col justify-end p-8">
              <div class="space-y-3">
                <div class="flex items-center gap-2">
                  {isExt(secondary) && <and-badge variant="secondary" class="text-[9px] uppercase">Medium</and-badge>}
                  <and-badge variant="outline" class="text-[10px] uppercase tracking-[0.15em]">
                    <FormattedDate date={secondary.data.pubDate} />
                  </and-badge>
                </div>
                <h3 class="text-xl font-bold leading-tight text-foreground transition-colors group-hover:text-primary-600">
                  {secondary.data.title}
                </h3>
              </div>
            </div>
          </and-card>
        </a>
      )}

      {/* ── Remaining cards: 4 cols each — compact with hero ── */}
      {rest.map((post) => (
        <a
          href={postHref(post)}
          target={isExt(post) ? "_blank" : undefined}
          rel={isExt(post) ? "noopener noreferrer" : undefined}
          class="group block md:col-span-4"
        >
          <and-card variant="default" class="bento-card relative h-full overflow-hidden rounded-2xl">
            {heroSrc(post) ? (
              <div class="absolute inset-0">
                <img
                  src={heroSrc(post)}
                  alt={post.data.title}
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--background)/0.94)] via-[hsl(var(--surface)/0.5)] to-[hsl(var(--surface)/0.15)]" />
              </div>
            ) : (
              <div class="absolute inset-0 -z-10">
                <div class="absolute -left-1/4 -top-1/4 h-3/4 w-3/4 rounded-full bg-primary-300/10 blur-3xl" />
              </div>
            )}

            <div class="relative z-10 flex h-full flex-col justify-end p-6">
              <div class="space-y-2">
                <div class="flex items-center gap-2">
                  {isExt(post) && <and-badge variant="secondary" class="text-[9px] uppercase">Medium</and-badge>}
                  <and-badge variant="secondary" class="text-[10px] uppercase tracking-[0.15em]">
                    <FormattedDate date={post.data.pubDate} />
                  </and-badge>
                </div>
                <h3 class="text-lg font-bold leading-snug text-foreground transition-colors group-hover:text-primary-600">
                  {post.data.title}
                </h3>
              </div>
            </div>
          </and-card>
        </a>
      ))}

    </div>
  );
})}
