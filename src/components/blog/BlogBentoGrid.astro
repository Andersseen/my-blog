---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../FormattedDate.astro';
import PostCard from './PostCard.astro';
import { type Dictionary, type Locale, toLocalePath } from '../../i18n';

interface Props {
  posts: CollectionEntry<'blog'>[];
  locale: Locale;
  messages: Dictionary;
}

const { posts, locale, messages } = Astro.props;

const featured = posts[0];
const secondary = posts[1];
const compactLeft = posts[2];
const compactRight = posts[3];
const horizontals = posts.slice(4, 6);
const remaining = posts.slice(6);
---

<style>
  .bento-card {
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease;
  }

  .bento-card:hover {
    transform: translateY(-4px);
  }

  .editorial-gradient {
    background: linear-gradient(
      135deg,
      hsl(var(--primary-500)) 0%,
      hsl(var(--primary-700)) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

{featured && (
  <div class="grid grid-cols-1 gap-5 md:grid-cols-12 md:auto-rows-[210px]">

    <!-- Featured article: 8 cols × 2 rows -->
    <a
      href={toLocalePath(locale, `/blog/${featured.id}/`)}
      class="bento-card group relative overflow-hidden rounded-2xl border border-[hsl(var(--primary-300)/0.14)] bg-[hsl(var(--surface-container-low))] md:col-span-8 md:row-span-2"
    >
      {featured.data.heroImage ? (
        <div class="absolute inset-0">
          <Image
            width={1200}
            height={640}
            src={featured.data.heroImage}
            alt={featured.data.title}
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 grayscale group-hover:grayscale-0"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--background)/0.96)] via-[hsl(var(--surface)/0.45)] to-transparent" />
        </div>
      ) : (
        <div class="absolute inset-0 -z-10">
          <div class="absolute -left-1/4 -top-1/4 h-3/4 w-3/4 rounded-full bg-[hsl(var(--primary-300)/0.07)] blur-3xl" />
          <div class="absolute -right-1/4 bottom-0 h-1/2 w-1/2 rounded-full bg-[hsl(var(--secondary)/0.05)] blur-3xl" />
        </div>
      )}

      <div class="relative z-10 flex h-full flex-col justify-end p-8 md:p-12">
        <div class="space-y-4">
          <span class="inline-block rounded-lg border border-[hsl(var(--secondary)/0.3)] bg-[hsl(var(--surface)/0.65)] px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.15em] text-[hsl(var(--secondary))] backdrop-blur-sm">
            <FormattedDate date={featured.data.pubDate} />
          </span>
          <h2 class="text-3xl font-bold leading-tight tracking-tight text-foreground transition-colors group-hover:text-[hsl(var(--primary-600))] md:text-4xl">
            {featured.data.title}
          </h2>
          <p class="line-clamp-2 max-w-xl text-[hsl(var(--muted-foreground))]">
            {featured.data.description}
          </p>
        </div>
      </div>
    </a>

    <!-- Secondary article: 4 cols × 2 rows -->
    {secondary && (
      <a
        href={toLocalePath(locale, `/blog/${secondary.id}/`)}
        class="bento-card group flex flex-col rounded-2xl border border-[hsl(var(--primary-300)/0.12)] bg-[hsl(var(--surface-container))] p-8 transition-colors hover:bg-[hsl(var(--surface-container-high))] md:col-span-4 md:row-span-2"
      >
        <div class="mb-auto space-y-6">
          <div class="editorial-gradient flex h-12 w-12 items-center justify-center rounded-xl shadow-lg shadow-[hsl(var(--primary-500)/0.15)]">
            <span class="text-xl font-bold text-white">↗</span>
          </div>
          <h3 class="text-2xl font-bold leading-tight text-foreground transition-colors group-hover:text-[hsl(var(--primary-600))]">
            {secondary.data.title}
          </h3>
        </div>
        <div class="mt-8 space-y-3">
          <p class="text-sm leading-relaxed text-[hsl(var(--muted-foreground))]">
            {secondary.data.description}
          </p>
          <span class="block text-[10px] font-semibold uppercase tracking-[0.15em] text-[hsl(var(--muted-foreground))]">
            <FormattedDate date={secondary.data.pubDate} />
          </span>
        </div>
      </a>
    )}

    <!-- Row 3 left: compact card -->
    {compactLeft && (
      <a
        href={toLocalePath(locale, `/blog/${compactLeft.id}/`)}
        class="bento-card group flex flex-col rounded-2xl border border-[hsl(var(--primary-300)/0.08)] bg-[hsl(var(--surface-container-low))] p-6 transition-all hover:border-[hsl(var(--primary-400)/0.3)] md:col-span-4"
      >
        <div class="mb-auto">
          <div class="mb-3 flex items-start justify-between">
            <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-[hsl(var(--secondary))]">
              <FormattedDate date={compactLeft.data.pubDate} />
            </span>
            <span class="text-sm text-[hsl(var(--muted-foreground))] opacity-0 transition-opacity group-hover:opacity-100">↗</span>
          </div>
          <h3 class="text-xl font-bold leading-snug text-foreground transition-colors group-hover:text-[hsl(var(--primary-600))]">
            {compactLeft.data.title}
          </h3>
        </div>
        <p class="mt-3 line-clamp-2 text-sm text-[hsl(var(--muted-foreground))]">
          {compactLeft.data.description}
        </p>
      </a>
    )}

    <!-- Quote interstitial: glass card -->
    <div class="flex items-center justify-center rounded-2xl border border-[hsl(var(--primary-300)/0.1)] bg-[hsl(var(--surface-container)/0.6)] p-6 text-center backdrop-blur-md md:col-span-4">
      <p class="text-sm italic leading-relaxed text-[hsl(var(--muted-foreground))]">
        &ldquo;{messages.blog.latestDescription}&rdquo;
      </p>
    </div>

    <!-- Row 3 right: compact card -->
    {compactRight && (
      <a
        href={toLocalePath(locale, `/blog/${compactRight.id}/`)}
        class="bento-card group flex flex-col rounded-2xl border border-[hsl(var(--primary-300)/0.08)] bg-[hsl(var(--surface-container-low))] p-6 transition-all hover:border-[hsl(var(--primary-400)/0.3)] md:col-span-4"
      >
        <div class="mb-auto">
          <div class="mb-3 flex items-start justify-between">
            <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-[hsl(var(--secondary))]">
              <FormattedDate date={compactRight.data.pubDate} />
            </span>
            <span class="text-sm text-[hsl(var(--muted-foreground))] opacity-0 transition-opacity group-hover:opacity-100">↗</span>
          </div>
          <h3 class="text-xl font-bold leading-snug text-foreground transition-colors group-hover:text-[hsl(var(--primary-600))]">
            {compactRight.data.title}
          </h3>
        </div>
        <p class="mt-3 line-clamp-2 text-sm text-[hsl(var(--muted-foreground))]">
          {compactRight.data.description}
        </p>
      </a>
    )}

    <!-- Row 4: horizontal cards (posts 4+5) -->
    {horizontals.map((post) => (
      <a
        href={toLocalePath(locale, `/blog/${post.id}/`)}
        class="bento-card group flex items-center gap-6 rounded-2xl border border-[hsl(var(--primary-300)/0.1)] bg-[hsl(var(--surface-container-high))] p-8 transition-colors md:col-span-6"
      >
        <div class="flex-1">
          <span class="mb-2 block text-[10px] font-semibold uppercase tracking-[0.15em] text-[hsl(var(--secondary))]">
            <FormattedDate date={post.data.pubDate} />
          </span>
          <h3 class="mb-1.5 text-xl font-bold leading-snug text-foreground transition-colors group-hover:text-[hsl(var(--primary-600))]">
            {post.data.title}
          </h3>
          <p class="line-clamp-1 text-sm text-[hsl(var(--muted-foreground))]">
            {post.data.description}
          </p>
        </div>
        <span class="shrink-0 text-3xl text-[hsl(var(--muted-foreground))] transition-colors group-hover:text-[hsl(var(--primary-600))]">→</span>
      </a>
    ))}

  </div>
)}

<!-- Remaining posts (7th onwards) — regular grid -->
{remaining.length > 0 && (
  <ul class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {remaining.map((post) => (
      <li class="h-full">
        <PostCard post={post} locale={locale} />
      </li>
    ))}
  </ul>
)}
