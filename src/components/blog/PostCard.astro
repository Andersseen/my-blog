---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FormattedDate from '../FormattedDate.astro';
import { type Locale, toLocalePath } from '../../i18n';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      heroImage?: ImageMetadata;
    };
  };
  locale: Locale;
}

const { post, locale } = Astro.props;
---

<a
  href={toLocalePath(locale, `/blog/${post.id}/`)}
  class="group flex h-full flex-col overflow-hidden rounded-2xl border border-primary-300/35 bg-[hsl(var(--surface)/0.82)] p-4 shadow-[0_10px_30px_-18px_hsl(var(--primary-900)/0.55)] transition hover:-translate-y-1 hover:border-primary-400/55 hover:shadow-[0_14px_34px_-18px_hsl(var(--primary-800)/0.65)]"
>
  {
    post.data.heroImage && (
      <Image
        width={780}
        height={420}
        src={post.data.heroImage}
        alt={post.data.title}
        class="mb-4 h-48 w-full rounded-xl object-cover"
      />
    )
  }

  <div class="flex flex-1 flex-col">
    <h2 class="text-xl font-semibold tracking-tight text-foreground group-hover:text-primary-800">{post.data.title}</h2>
    <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">{post.data.description}</p>
  </div>
  <p class="mt-4 text-xs font-medium uppercase tracking-wide text-[hsl(var(--muted-foreground))]">
    <FormattedDate date={post.data.pubDate} />
  </p>
</a>
