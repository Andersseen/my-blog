---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FormattedDate from '../FormattedDate.astro';
import { type Locale, toLocalePath } from '../../i18n';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      heroImage?: ImageMetadata;
    };
  };
  locale: Locale;
}

const { post, locale } = Astro.props;
---

<style>
  .bento-card {
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease;
  }

  .bento-card:hover {
    transform: translateY(-4px);
  }
</style>

<a
  href={toLocalePath(locale, `/blog/${post.id}/`)}
  class="group block h-full"
>
  <and-card
    variant="elevated"
    class="bento-card flex h-full flex-col overflow-hidden rounded-2xl transition-shadow"
  >
    {
      post.data.heroImage && (
        <div class="relative overflow-hidden">
          <Image
            width={780}
            height={420}
            src={post.data.heroImage}
            alt={post.data.title}
            class="h-44 w-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--surface)/0.6)] to-transparent" />
        </div>
      )
    }

    <div class="flex flex-1 flex-col p-5">
      <h2 class="text-lg font-bold tracking-tight leading-snug text-foreground transition-colors group-hover:text-[hsl(var(--primary-700))]">
        {post.data.title}
      </h2>
      <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">
        {post.data.description}
      </p>
      <div class="mt-4 flex items-center justify-between">
        <and-badge variant="outline" class="text-[10px] uppercase tracking-[0.15em]">
          <FormattedDate date={post.data.pubDate} />
        </and-badge>
        <span class="text-xs font-semibold uppercase tracking-widest text-[hsl(var(--primary-600))] opacity-0 transition-opacity group-hover:opacity-100">
          →
        </span>
      </div>
    </div>
  </and-card>
</a>
