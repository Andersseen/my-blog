---
import { type Locale, toLocalePath } from '../../i18n';
import type { Dictionary } from '../../i18n';

interface Props {
  locale: Locale;
  messages: Dictionary;
}

const { locale, messages } = Astro.props;
---

<div class="flex flex-wrap items-center gap-3 pt-2">
  <a
    href={toLocalePath(locale, '/blog')}
    class="inline-flex items-center justify-center rounded-full border border-[hsl(var(--primary-600))] bg-[hsl(var(--primary-600))] px-5 py-2.5 text-xs font-semibold uppercase tracking-widest text-white transition hover:bg-[hsl(var(--primary-700))] hover:border-[hsl(var(--primary-700))]"
  >
    {messages.nav.blog}
  </a>
</div>
