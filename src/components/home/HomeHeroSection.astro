---
import type { Dictionary, Locale } from '../../i18n';
import HomeEditorialPanel from './HomeEditorialPanel.astro';
import HomeHeroActions from './HomeHeroActions.astro';

interface Props {
  locale: Locale;
  messages: Dictionary;
}

const { locale, messages } = Astro.props;
---

<section class="home-hero mx-auto max-w-5xl">
  <div class="grid grid-cols-1 gap-4 md:grid-cols-3">

    <!-- Large hero card (2 cols, spans both right-side rows) -->
    <and-card
      variant="elevated"
      class="bento-card flex min-h-[340px] flex-col justify-end rounded-2xl p-8 home-reveal md:col-span-2 md:row-span-2"
      style="--reveal-delay: 40ms;"
    >
      <div class="space-y-5">
        <and-badge variant="secondary" class="inline-block w-fit text-[11px] uppercase tracking-[0.15em]">
          {messages.home.badge}
        </and-badge>
        <h1 class="text-4xl font-bold tracking-tight leading-[1.1] text-foreground sm:text-5xl">
          {messages.home.headline}
        </h1>
        <p class="text-base leading-relaxed text-muted-foreground">
          {messages.home.description}
        </p>
        <HomeHeroActions locale={locale} messages={messages} />
      </div>
    </and-card>

    <!-- Editorial panel (top-right) -->
    <div class="h-full home-reveal" style="--reveal-delay: 130ms;">
      <HomeEditorialPanel messages={messages} />
    </div>

    <!-- Focus / latest teaser card (bottom-right) -->
    <and-card
      variant="default"
      class="bento-card flex flex-col justify-between rounded-2xl p-6 home-reveal"
      style="--reveal-delay: 210ms;"
    >
      <and-badge variant="outline" class="w-fit text-[10px] uppercase tracking-[0.2em]">
        {messages.blog.latestTitle}
      </and-badge>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
        {messages.blog.latestDescription}
      </p>
    </and-card>

  </div>
</section>
