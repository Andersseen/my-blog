---
import type { CollectionEntry } from 'astro:content';
import PostCard from '../blog/PostCard.astro';
import type { Dictionary, Locale } from '../../i18n';
import { toLocalePath } from '../../i18n';

interface Props {
  locale: Locale;
  messages: Dictionary;
  posts: CollectionEntry<'blog'>[];
}

const { locale, messages, posts } = Astro.props;
---

<section class="home-reveal mx-auto mt-12 max-w-5xl space-y-6" style="--reveal-delay: 280ms;">
  <header class="flex items-end justify-between gap-4">
    <div class="space-y-1">
      <h2 class="text-2xl font-bold tracking-tight text-foreground">{messages.blog.latestTitle}</h2>
      <p class="text-sm text-[hsl(var(--muted-foreground))]">{messages.blog.latestDescription}</p>
    </div>
    <and-button
      href={toLocalePath(locale, '/blog')}
      variant="outline"
      size="sm"
      class="shrink-0"
      custom-class="rounded-full px-5"
    >
      {messages.nav.blog}
    </and-button>
  </header>

  <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => (
      <li class="h-full">
        <PostCard post={post} locale={locale} />
      </li>
    ))}
  </ul>
</section>
