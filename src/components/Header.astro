---
import { AUTHOR_USERNAME, SITE_TITLE } from '../consts';
import { type Dictionary, type Locale, stripLocaleFromPath, toLocalePath } from '../i18n';
import LanguageDropdown from './i18n/LanguageDropdown.astro';
import ThemeToggle from './theme/ThemeToggle.astro';

interface Props {
  locale: Locale;
  messages: Dictionary;
}

const { locale, messages } = Astro.props;

const currentPath = stripLocaleFromPath(Astro.url.pathname);
const homePath = toLocalePath(locale, '/');

const isActive = (path: string) => {
  if (path === '/') return !currentPath.startsWith('/blog');
  return currentPath.startsWith(path);
};

const navLinks = [
  { label: messages.nav.home, href: toLocalePath(locale, '/'), active: isActive('/') },
  { label: messages.nav.blog, href: toLocalePath(locale, '/blog'), active: isActive('/blog') },
];

const navItems = navLinks.map(link => ({
  id: link.href,
  label: link.label,
  href: link.href
}));

const activeItemId = navLinks.find(link => link.active)?.href;
---

<and-navbar
  variant="default"
  position="sticky"
  class="w-full"
  items={JSON.stringify(navItems)}
  active-item={activeItemId}
>
  <!-- Brand -->
  <a slot="brand" href={homePath} class="group inline-flex shrink-0 flex-col leading-none text-foreground">
    <span class="text-base font-bold tracking-tight transition-colors group-hover:text-[hsl(var(--primary-600))] sm:text-lg">
      {SITE_TITLE}
    </span>
    <span class="text-[10px] font-medium uppercase tracking-[0.18em] text-[hsl(var(--muted-foreground))]">
      @{AUTHOR_USERNAME}
    </span>
  </a>

  <!-- Desktop Controls -->
  <div slot="end" class="flex shrink-0 items-center gap-2">
    <LanguageDropdown locale={locale} messages={messages} currentPath={currentPath} class="min-w-[74px]" />
    <ThemeToggle messages={messages} />
  </div>

  <!-- Mobile Title -->
  <span slot="mobile-title" class="text-[0.78rem] font-bold tracking-[0.12em] uppercase text-[hsl(var(--muted-foreground))]">
    {messages.nav.menu}
  </span>

  <!-- Mobile Controls -->
  <div slot="mobile-actions" class="grid gap-3 border-t border-[hsl(var(--primary-300)/0.28)] pt-4">
    <LanguageDropdown locale={locale} messages={messages} currentPath={currentPath} />
    <ThemeToggle messages={messages} />
  </div>
</and-navbar>

<script>
  const nav = document.querySelector<HTMLElement & { activeItem: string }>('and-navbar');
  if (nav) {
    nav.addEventListener('navItemClick', ((e: CustomEvent<string>) => {
      nav.activeItem = e.detail;
    }) as EventListener);
  }
</script>
