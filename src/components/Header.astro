---
import { AUTHOR_USERNAME, SITE_TITLE } from '../consts';
import { type Dictionary, type Locale, stripLocaleFromPath, toLocalePath } from '../i18n';
import LanguageDropdown from './i18n/LanguageDropdown.astro';
import ThemeToggle from './theme/ThemeToggle.astro';

interface Props {
  locale: Locale;
  messages: Dictionary;
}

const { locale, messages } = Astro.props;

const currentPath = stripLocaleFromPath(Astro.url.pathname);
const homePath = toLocalePath(locale, '/');

const isActive = (path: string) => {
  if (path === '/') return !currentPath.startsWith('/blog');
  return currentPath.startsWith(path);
};

const navLinks = [
  { label: messages.nav.home, href: toLocalePath(locale, '/'), active: isActive('/') },
  { label: messages.nav.blog, href: toLocalePath(locale, '/blog'), active: isActive('/blog') },
];
---

<style>
  .site-header {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
</style>

<header class="site-header sticky top-0 z-50 w-full">
  <nav
    class="mx-auto flex h-16 max-w-5xl items-center justify-between gap-6 px-4 sm:px-6 lg:px-8"
    aria-label={messages.nav.aria}
  >
    <!-- Brand -->
    <a href={homePath} class="group inline-flex shrink-0 flex-col leading-none text-foreground">
      <span class="text-base font-bold tracking-tight transition-colors group-hover:text-[hsl(var(--primary-600))] sm:text-lg">
        {SITE_TITLE}
      </span>
      <span class="text-[10px] font-medium uppercase tracking-[0.18em] text-[hsl(var(--muted-foreground))]">
        @{AUTHOR_USERNAME}
      </span>
    </a>

    <!-- Nav links -->
    <ul class="flex items-center gap-6" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={link.active ? 'page' : undefined}
            class:list={[
              'relative text-sm font-medium tracking-wide transition-colors',
              link.active
                ? 'text-foreground after:absolute after:-bottom-0.5 after:left-0 after:h-px after:w-full after:bg-[hsl(var(--primary-500))]'
                : 'text-[hsl(var(--muted-foreground))] hover:text-foreground',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Controls -->
    <div class="flex shrink-0 items-center gap-2">
      <LanguageDropdown locale={locale} messages={messages} currentPath={currentPath} class="min-w-[74px]" />
      <ThemeToggle messages={messages} />
    </div>
  </nav>
  <div class="h-px bg-[hsl(var(--primary-300)/0.18)]"></div>
</header>
