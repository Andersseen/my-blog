---
import { AUTHOR_USERNAME, SITE_TITLE } from '../consts';
import { type Dictionary, type Locale, stripLocaleFromPath, toLocalePath } from '../i18n';
import LanguageDropdown from './i18n/LanguageDropdown.astro';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './theme/ThemeToggle.astro';

interface Props {
	locale: Locale;
	messages: Dictionary;
}

const { locale, messages } = Astro.props;

const currentPath = stripLocaleFromPath(Astro.url.pathname);
const homePath = toLocalePath(locale, '/');
---

<header class="py-6">
	<div class="border-b border-primary-200 pb-4">
		<div class="hidden items-center justify-between gap-4 md:flex">
			<a href={homePath} class="inline-flex items-baseline gap-2 text-xl font-semibold tracking-tight text-foreground">
				{SITE_TITLE}
				<span class="text-xs font-medium uppercase tracking-[0.18em] text-[hsl(var(--muted-foreground))]">@{AUTHOR_USERNAME}</span>
			</a>
			<div class="flex flex-wrap items-center gap-3 lg:gap-4">
				<nav class="flex items-center gap-1 sm:gap-2" aria-label="Main navigation">
					<HeaderLink href={toLocalePath(locale, '/')}>{messages.nav.home}</HeaderLink>
					<HeaderLink href={toLocalePath(locale, '/blog')}>{messages.nav.blog}</HeaderLink>
					<HeaderLink href={toLocalePath(locale, '/about')}>{messages.nav.about}</HeaderLink>
				</nav>
				<div class="flex items-center gap-2 pl-2 border-l border-primary-200">
					<LanguageDropdown locale={locale} messages={messages} currentPath={currentPath} />
					<ThemeToggle messages={messages} />
				</div>
			</div>
		</div>

		<div class="space-y-3 md:hidden" data-mobile-header>
			<div class="flex items-start justify-between gap-3">
				<a href={homePath} class="inline-flex min-w-0 flex-col gap-1 text-foreground">
					<span class="truncate text-lg font-semibold tracking-tight">{SITE_TITLE}</span>
					<span class="text-[11px] font-medium uppercase tracking-[0.18em] text-[hsl(var(--muted-foreground))]">@{AUTHOR_USERNAME}</span>
				</a>
				<div class="flex shrink-0 items-center gap-2">
					<LanguageDropdown locale={locale} messages={messages} currentPath={currentPath} class="min-w-[74px]" />
					<ThemeToggle messages={messages} class="!px-1.5" />
					<button
						type="button"
            class="inline-flex h-10 min-w-[44px] items-center justify-center rounded-md border border-primary-300 bg-[hsl(var(--surface)/0.82)] px-3 text-xs font-semibold uppercase tracking-wide text-foreground transition hover:bg-primary-100"
						data-mobile-nav-toggle
            data-mobile-open-label={messages.nav.menu}
            data-mobile-close-label={messages.nav.closeMenu}
						aria-expanded="false"
						aria-controls="mobile-main-navigation"
						aria-label={messages.nav.menu}
					>
						<span data-mobile-nav-toggle-label>{messages.nav.menu}</span>
					</button>
				</div>
			</div>

			<nav
				id="mobile-main-navigation"
				aria-label="Main navigation"
				class="hidden rounded-xl border border-primary-200 bg-[hsl(var(--surface)/0.92)] p-2"
				data-mobile-nav-panel
			>
				<div class="flex flex-col gap-1">
					<HeaderLink href={toLocalePath(locale, '/')}>{messages.nav.home}</HeaderLink>
					<HeaderLink href={toLocalePath(locale, '/blog')}>{messages.nav.blog}</HeaderLink>
					<HeaderLink href={toLocalePath(locale, '/about')}>{messages.nav.about}</HeaderLink>
				</div>
			</nav>
		</div>
	</div>
</header>

<script>
  const mountMobileHeader = () => {
    const root = document.querySelector<HTMLElement>('[data-mobile-header]');
    if (!root || root.dataset.bound === 'true') {
      return;
    }

    const toggle = root.querySelector<HTMLButtonElement>('[data-mobile-nav-toggle]');
    const toggleLabel = root.querySelector<HTMLElement>('[data-mobile-nav-toggle-label]');
    const panel = root.querySelector<HTMLElement>('[data-mobile-nav-panel]');

    if (!toggle || !panel) {
      return;
    }

    root.dataset.bound = 'true';
    const openLabel = toggle.getAttribute('data-mobile-open-label') ?? 'Menu';
    const closeLabel = toggle.getAttribute('data-mobile-close-label') ?? 'Close';

    const setOpen = (isOpen: boolean) => {
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      panel.classList.toggle('hidden', !isOpen);
      if (toggleLabel) {
        toggleLabel.textContent = isOpen ? closeLabel : openLabel;
      }
    };

    setOpen(false);

    toggle.addEventListener('click', () => {
      const nextOpen = toggle.getAttribute('aria-expanded') !== 'true';
      setOpen(nextOpen);
      if (nextOpen) {
        panel.querySelector<HTMLAnchorElement>('a')?.focus();
      }
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node)) {
        return;
      }

      if (root.contains(event.target)) {
        return;
      }

      if (toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') {
        return;
      }

      if (toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    window.addEventListener('resize', () => {
      if (window.matchMedia('(min-width: 768px)').matches) {
        setOpen(false);
      }
    });
  };

  void mountMobileHeader();
</script>
