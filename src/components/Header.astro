---
import { AUTHOR_USERNAME, SITE_TITLE } from '../consts';
import { type Dictionary, type Locale, stripLocaleFromPath, toLocalePath } from '../i18n';
import LanguageDropdown from './i18n/LanguageDropdown.astro';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './theme/ThemeToggle.astro';

interface Props {
	locale: Locale;
	messages: Dictionary;
}

const { locale, messages } = Astro.props;

const currentPath = stripLocaleFromPath(Astro.url.pathname);
const homePath = toLocalePath(locale, '/');
---

<header class="py-6">
	<div class="flex flex-wrap items-center justify-between gap-4 border-b border-primary-200 pb-4">
		<a href={homePath} class="inline-flex items-baseline gap-2 text-xl font-semibold tracking-tight text-foreground">
			{SITE_TITLE}
			<span class="text-xs font-medium uppercase tracking-[0.18em] text-[hsl(var(--muted-foreground))]">@{AUTHOR_USERNAME}</span>
		</a>
		<div class="flex items-center gap-3 sm:gap-6">
			<nav class="flex items-center gap-1 sm:gap-2" aria-label="Main navigation">
				<HeaderLink href={toLocalePath(locale, '/')}>{messages.nav.home}</HeaderLink>
				<HeaderLink href={toLocalePath(locale, '/blog')}>{messages.nav.blog}</HeaderLink>
				<HeaderLink href={toLocalePath(locale, '/about')}>{messages.nav.about}</HeaderLink>
			</nav>
			<LanguageDropdown locale={locale} messages={messages} currentPath={currentPath} />
			<ThemeToggle messages={messages} />
		</div>
	</div>
</header>
