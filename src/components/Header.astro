---
import { AUTHOR_USERNAME, SITE_TITLE } from '../consts';
import { type Dictionary, type Locale, stripLocaleFromPath, toLocalePath } from '../i18n';
import LanguageDropdown from './i18n/LanguageDropdown.astro';
import ThemeToggle from './theme/ThemeToggle.astro';

interface Props {
	locale: Locale;
	messages: Dictionary;
}

const { locale, messages } = Astro.props;

const currentPath = stripLocaleFromPath(Astro.url.pathname);
const homePath = toLocalePath(locale, '/');

const navItems = [
  { id: 'home', label: messages.nav.home, href: toLocalePath(locale, '/') },
  { id: 'blog', label: messages.nav.blog, href: toLocalePath(locale, '/blog') },
  { id: 'about', label: messages.nav.about, href: toLocalePath(locale, '/about') },
];

const resolveActiveNavItem = (path: string): string => {
  if (path.startsWith('/blog')) {
    return 'blog';
  }

  if (path.startsWith('/about')) {
    return 'about';
  }

  return 'home';
};

const activeNavItem = resolveActiveNavItem(currentPath);
---

<header class="py-6">
	<div class="border-b border-primary-200 pb-4">
		<and-navbar
			class="block"
			data-main-navbar
			data-mobile-open-label={messages.nav.menu}
			data-mobile-close-label={messages.nav.closeMenu}
			aria-nav-label={messages.nav.aria}
			items={JSON.stringify(navItems)}
			active-item={activeNavItem}
			item-variant="underline"
			mobile-breakpoint="640"
			minimal-breakpoint="768"
			compact-breakpoint="768"
			variant="glass"
		>
			<a slot="start" href={homePath} class="inline-flex min-w-0 flex-col gap-1 text-foreground">
				<span class="truncate text-lg font-semibold tracking-tight sm:text-xl">{SITE_TITLE}</span>
				<span class="text-[11px] font-medium uppercase tracking-[0.18em] text-[hsl(var(--muted-foreground))]">@{AUTHOR_USERNAME}</span>
			</a>

			<LanguageDropdown slot="end" locale={locale} messages={messages} currentPath={currentPath} class="min-w-[74px]" />
			<ThemeToggle slot="end" messages={messages} />

			<span slot="mobile-title" class="text-sm font-semibold uppercase tracking-wide">{messages.nav.menu}</span>
		</and-navbar>
	</div>
</header>

<script>
  const syncMobileToggleLabel = (navbar: HTMLElement): boolean => {
    const toggleButton = navbar.shadowRoot?.querySelector<HTMLButtonElement>('.mobile-toggle-btn');

    if (!toggleButton) {
      return false;
    }

    const openLabel = navbar.getAttribute('data-mobile-open-label') ?? 'Menu';
    const closeLabel = navbar.getAttribute('data-mobile-close-label') ?? 'Close';
    const isExpanded =
      toggleButton.getAttribute('aria-expanded') === 'true' ||
      toggleButton.getAttribute('data-state') === 'open';

    toggleButton.setAttribute('aria-label', isExpanded ? closeLabel : openLabel);

    return isExpanded;
  };

  const mountHeaderNavbars = async () => {
    if (typeof customElements !== 'undefined') {
      await customElements.whenDefined('and-navbar');
    }

    const navbars = document.querySelectorAll<HTMLElement>('[data-main-navbar]');

    navbars.forEach((navbar) => {
      if (navbar.dataset.bound === 'true') {
        return;
      }

      navbar.dataset.bound = 'true';
      navbar.dataset.mobileMenuOpen = 'false';

      const sync = () => {
        const wasOpen = navbar.dataset.mobileMenuOpen === 'true';
        const isOpen = syncMobileToggleLabel(navbar);

        if (wasOpen && !isOpen) {
          navbar.shadowRoot?.querySelector<HTMLButtonElement>('.mobile-toggle-btn')?.focus();
        }

        navbar.dataset.mobileMenuOpen = isOpen ? 'true' : 'false';
      };

      const onEscape = (event: Event) => {
        const keyboardEvent = event as KeyboardEvent;

        if (keyboardEvent.key !== 'Escape' || navbar.dataset.mobileMenuOpen !== 'true') {
          return;
        }

        window.setTimeout(() => {
          navbar.shadowRoot?.querySelector<HTMLButtonElement>('.mobile-toggle-btn')?.focus();
        }, 0);
      };

      sync();
      navbar.addEventListener('mobileMenuChange', sync);
      navbar.addEventListener('responsiveStageChange', sync);
      document.addEventListener('keydown', onEscape);

      const observer = new MutationObserver(sync);
      const toggleButton = navbar.shadowRoot?.querySelector('.mobile-toggle-btn');

      if (toggleButton) {
        observer.observe(toggleButton, {
          attributes: true,
          attributeFilter: ['aria-expanded'],
        });
      }

      window.addEventListener(
        'beforeunload',
        () => {
          observer.disconnect();
          navbar.removeEventListener('mobileMenuChange', sync);
          navbar.removeEventListener('responsiveStageChange', sync);
          document.removeEventListener('keydown', onEscape);
        },
        { once: true },
      );
    });
  };

  void mountHeaderNavbars();
</script>
