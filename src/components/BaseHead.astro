---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { AUTHOR_MEDIUM_URL, AUTHOR_PORTFOLIO_URL } from '../consts';
import { LOCALES, type Locale, getLocaleFromPath, stripLocaleFromPath, toLocalePath } from '../i18n';
import SeoMetaTags from './seo/SeoMetaTags.astro';
import SeoFavicons from './seo/SeoFavicons.astro';
import SeoStructuredData from './seo/SeoStructuredData.astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	noindex?: boolean;
	pageType?: 'website' | 'article';
	locale?: Locale;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = FallbackImage,
	noindex = false,
	pageType = 'website',
	locale = getLocaleFromPath(Astro.url.pathname),
} = Astro.props;

const basePath = stripLocaleFromPath(Astro.url.pathname);
const pageURL = canonicalURL.toString();
const imageURL = new URL(image.src, Astro.site).toString();

const alternateLinks = LOCALES.map((lang) => ({
	lang,
	href: new URL(toLocalePath(lang, basePath), Astro.site),
}));
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />
<meta name="color-scheme" content="light dark" />

<SeoFavicons />

<link rel="me" href={AUTHOR_PORTFOLIO_URL} />
<link rel="me" href={AUTHOR_MEDIUM_URL} />

{
	alternateLinks.map((item) => (
		<link rel="alternate" hreflang={item.lang} href={item.href} />
	))
}
<link rel="alternate" hreflang="x-default" href={new URL(toLocalePath('es', basePath), Astro.site)} />

<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={title}
	href={new URL('rss.xml', Astro.site)}
/>

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<SeoMetaTags
	title={title}
	description={description}
	canonicalURL={pageURL}
	pageURL={pageURL}
	imageURL={imageURL}
	locale={locale}
	noindex={noindex}
/>

<SeoStructuredData
	title={title}
	description={description}
	pageURL={pageURL}
	imageURL={imageURL}
	locale={locale}
	pageType={pageType}
/>
