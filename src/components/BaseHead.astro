---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { AUTHOR_MEDIUM_URL, AUTHOR_PORTFOLIO_URL } from '../consts';
import SeoMetaTags from './seo/SeoMetaTags.astro';
import SeoFavicons from './seo/SeoFavicons.astro';
import SeoStructuredData from './seo/SeoStructuredData.astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	noindex?: boolean;
	pageType?: 'website' | 'article';
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage, noindex = false, pageType = 'website' } = Astro.props;
const pageURL = canonicalURL.toString();
const imageURL = new URL(image.src, Astro.site).toString();
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<meta name="generator" content={Astro.generator} />
<meta name="color-scheme" content="light dark" />

<SeoFavicons />

<link rel="me" href={AUTHOR_PORTFOLIO_URL} />
<link rel="me" href={AUTHOR_MEDIUM_URL} />

<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={title}
	href={new URL('rss.xml', Astro.site)}
/>

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<SeoMetaTags
	title={title}
	description={description}
	canonicalURL={pageURL}
	pageURL={pageURL}
	imageURL={imageURL}
	noindex={noindex}
/>

<SeoStructuredData
	title={title}
	description={description}
	pageURL={pageURL}
	imageURL={imageURL}
	pageType={pageType}
/>
