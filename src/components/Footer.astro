---
import { AUTHOR_MEDIUM_URL, AUTHOR_NAME, AUTHOR_PORTFOLIO_URL } from '../consts';
import type { Dictionary } from '../i18n';

interface Props {
	messages: Dictionary;
}

const { messages } = Astro.props;
const today = new Date();
---

<footer class="mt-16 border-t border-primary-200 py-8 text-sm text-foreground/70">
	<div class="flex flex-col items-center justify-between gap-3 sm:flex-row">
		<p>&copy; {today.getFullYear()} {AUTHOR_NAME}. {messages.footer.rights}</p>
		<p class="flex items-center gap-3 text-foreground/60">
			<a class="inline-flex items-center gap-1 hover:text-primary-800" href={AUTHOR_PORTFOLIO_URL} rel="me noopener noreferrer" target="_blank">
				{messages.footer.portfolio}
				<and-icon name="external-link" size="13" aria-hidden="true"></and-icon>
			</a>
			<span aria-hidden="true">•</span>
			<a class="inline-flex items-center gap-1 hover:text-primary-800" href={AUTHOR_MEDIUM_URL} rel="me noopener noreferrer" target="_blank">
				{messages.footer.medium}
				<and-icon name="external-link" size="13" aria-hidden="true"></and-icon>
			</a>
		</p>
	</div>
</footer>
