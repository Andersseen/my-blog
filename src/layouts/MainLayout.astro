---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SkipLink from '../components/SkipLink.astro';
import type { ImageMetadata } from 'astro';
import { type Dictionary, type Locale, getI18n, getLangCode } from '../i18n';

interface Props {
  title: string;
  description: string;
  image?: ImageMetadata;
  lang?: string;
  pageType?: 'website' | 'article';
  locale?: Locale;
  messages?: Dictionary;
}

const detectedI18n = getI18n(Astro.url.pathname);

const {
  title,
  description,
  image,
  pageType = 'website',
  locale = detectedI18n.locale,
  messages = detectedI18n.messages,
  lang,
} = Astro.props;

const htmlLang = lang ?? getLangCode(locale);
---

<style>
  .app-backdrop {
    background:
      radial-gradient(
        circle at top,
        hsl(var(--backdrop-top) / 0.34) 0%,
        transparent 64%
      ),
      radial-gradient(
        circle at bottom,
        hsl(var(--backdrop-bottom) / 0.24) 0%,
        transparent 60%
      );
  }
</style>

<!doctype html>
<html lang={htmlLang} data-theme="light">
  <head>
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme-cache');
          var scheme = t === 'dark' || t === 'light' ? t : 
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', scheme);
          document.documentElement.style.colorScheme = scheme;
          window.__AND_ANIMATED__ = true;
        } catch (e) {}
      })();
    </script>
    <BaseHead title={title} description={description} image={image} pageType={pageType} locale={locale} />
    <script is:inline>
      // Native View Transitions API fallback
      if (typeof document !== 'undefined' && 'startViewTransition' in document) {
        document.addEventListener('click', (e) => {
          const link = e.target.closest('a');
          if (link && link.origin === location.origin && !link.hasAttribute('data-no-transition')) {
            e.preventDefault();
            const href = link.href;
            document.startViewTransition(() => {
              window.location.href = href;
            });
          }
        });
      }
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <SkipLink messages={messages} />
    <div class="relative min-h-screen">
      <div
        aria-hidden="true"
        class="app-backdrop pointer-events-none absolute inset-0 -z-10"
      ></div>

      <div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col px-4 sm:px-6 md:px-8 lg:px-8">
        <Header locale={locale} messages={messages} />
        <main id="main-content" class="flex-1 pb-8 pt-2" tabindex="-1">
          <slot />
        </main>
        <Footer messages={messages} />
      </div>
    </div>

    <script>
      import '../scripts/setup-andersseen';
      import { initTheme } from '../store/theme';

      void initTheme();

      // Register Service Worker
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then((registration) => {
              console.log('SW registered:', registration.scope);
            })
            .catch((error) => {
              console.warn('SW registration failed:', error);
            });
        });
      }
    </script>
  </body>
</html>
