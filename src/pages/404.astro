---
import MainLayout from '@/layouts/MainLayout.astro';
import { getI18n } from '@/i18n';
import { SITE_TITLE } from '@/consts';

const { locale, messages } = getI18n(Astro.url.pathname);
---

<MainLayout
  title={`${SITE_TITLE} | ${messages.nav.blog}`}
  description={messages.meta.siteDescription}
  locale={locale}
  messages={messages}
  noindex={true}
>
  <div class="flex min-h-[60vh] flex-col items-center justify-center text-center" role="alert" aria-live="polite">
    <span class="text-8xl font-bold tracking-tighter text-primary-300" aria-hidden="true">404</span>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-foreground">{messages.error?.notFoundTitle || 'Pagina no encontrada'}</h1>
    <p class="mt-3 max-w-md text-muted-foreground">{messages.error?.notFoundDescription || 'El contenido que buscas no existe o ha sido movido.'}</p>
    <a
      href={locale === 'es' ? '/' : `/${locale}`}
      class="mt-8 inline-flex items-center rounded-full bg-primary-600 px-6 py-3 text-sm font-medium text-white transition hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
    >
      {messages.error?.backToHome || 'Volver al inicio'}
    </a>
  </div>
</MainLayout>
