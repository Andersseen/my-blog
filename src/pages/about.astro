---
import MainLayout from '../layouts/MainLayout.astro';
import { getI18n } from '../i18n';

const { locale, messages } = getI18n(Astro.url.pathname);
---

<MainLayout
	title={messages.meta.aboutTitle}
	description={messages.meta.aboutDescription}
	locale={locale}
	messages={messages}
>
	<section class="mx-auto max-w-3xl space-y-5">
		<h1 class="text-3xl font-bold tracking-tight text-foreground">{messages.about.title}</h1>
		{messages.about.paragraphs.map((paragraph) => <p class="text-foreground/75">{paragraph}</p>)}
	</section>
</MainLayout>
