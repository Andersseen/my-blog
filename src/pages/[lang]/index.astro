---
import { getCollection } from 'astro:content';
import HomeHeroSection from '../../components/home/HomeHeroSection.astro';
import HomeLatestPostsSection from '../../components/home/HomeLatestPostsSection.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import { SITE_TITLE } from '../../consts';
import { getI18n } from '../../i18n';
import { unifyPosts, type BlogPost, type MediumPost } from '../../types/blog';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'ua' } }];
}

const { locale, messages } = getI18n(Astro.url.pathname);

let blogPosts: BlogPost[] = [];
try {
  blogPosts = await getCollection('blog');
} catch (error) {
  console.warn('Failed to load blog posts:', error);
}

let mediumPosts: MediumPost[] = [];
try {
  mediumPosts = await getCollection('medium');
} catch (error) {
  console.warn('Failed to load Medium posts:', error);
}

const unifiedPosts = unifyPosts(blogPosts, mediumPosts);
const latestPosts = unifiedPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<MainLayout
  title={SITE_TITLE}
  description={messages.meta.siteDescription}
  locale={locale}
  messages={messages}
>
  <HomeHeroSection locale={locale} messages={messages} />

  <HomeLatestPostsSection locale={locale} messages={messages} posts={latestPosts} />
</MainLayout>
