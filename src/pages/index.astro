---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[1.25fr_1fr] lg:items-center">
		<div class="space-y-6">
			<p class="inline-flex rounded-full border border-primary-300 bg-primary-100 px-3 py-1 text-sm font-semibold text-primary-800">
				Arquitectura Lista Para Escalar
			</p>
			<h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
				Blog sólido con Astro, TypeScript, Tailwind, Angular Islands y Testing.
			</h1>
			<p class="max-w-2xl text-lg text-foreground/75">
				Esta base incluye theming robusto con Nano Stores + Dexie, estructura modular y configuración de
				testing para evolucionar con confianza.
			</p>
		</div>
		<aside class="rounded-2xl border border-primary-200 bg-white/70 p-6 shadow-sm backdrop-blur">
			<h2 class="text-lg font-semibold text-foreground">Capas iniciales</h2>
			<ul class="mt-4 space-y-2 text-sm text-foreground/75">
				<li>Astro SSG/SSR con TypeScript estricto</li>
				<li>Theming semántico sin dependencia de dark:</li>
				<li>Persistencia local escalable en IndexedDB</li>
				<li>Preparado para pruebas unitarias y E2E</li>
			</ul>
		</aside>
	</section>
</MainLayout>
