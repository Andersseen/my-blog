---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-[1.25fr_1fr] lg:items-start">
		<div class="space-y-6">
			<p class="inline-flex rounded-full border border-primary-300/60 bg-primary-100/70 px-3 py-1 text-sm font-semibold text-primary-800">
				Andrii Pa • @Andersseen
			</p>
			<h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
				Articulos tecnicos en mi propio blog, con el mismo ADN visual de mi portfolio.
			</h1>
			<p class="max-w-2xl text-lg text-[hsl(var(--muted-foreground))]">
				Este espacio replica el estilo Andersseen Dev para publicar sobre Angular, TypeScript,
				design systems y arquitectura frontend sin depender solo de Medium.
			</p>
		</div>
		<aside class="rounded-2xl border border-primary-300/35 bg-[hsl(var(--surface)/0.82)] p-6 shadow-[0_10px_30px_-18px_hsl(var(--primary-900)/0.55)] backdrop-blur-md">
			<h2 class="text-lg font-semibold text-foreground">Linea editorial</h2>
			<ul class="mt-4 space-y-2 text-sm text-[hsl(var(--muted-foreground))]">
				<li>Arquitectura frontend escalable</li>
				<li>Experimentos reales con Angular y Web Components</li>
				<li>Tips de tooling, DX y calidad de codigo</li>
				<li>Contenido alineado con Andersseen Dev</li>
			</ul>
		</aside>
	</section>
</MainLayout>
