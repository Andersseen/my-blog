---
import MainLayout from '../layouts/MainLayout.astro';
import { getI18n } from '../i18n';
import { SITE_TITLE } from '../consts';

const { locale, messages } = getI18n(Astro.url.pathname);
---

<MainLayout
  title={`${SITE_TITLE} | Error`}
  description={messages.meta.siteDescription}
  locale={locale}
  messages={messages}
  noindex={true}
>
  <div class="flex min-h-[60vh] flex-col items-center justify-center text-center" role="alert" aria-live="assertive">
    <span class="text-8xl font-bold tracking-tighter text-destructive/30" aria-hidden="true">500</span>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-foreground">{messages.error?.serverErrorTitle || 'Error del servidor'}</h1>
    <p class="mt-3 max-w-md text-muted-foreground">{messages.error?.serverErrorDescription || 'Algo salio mal. Por favor, intenta de nuevo mas tarde.'}</p>
    <button
      onclick="window.location.reload()"
      class="mt-8 inline-flex items-center rounded-full bg-primary-600 px-6 py-3 text-sm font-medium text-white transition hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
    >
      {messages.error?.retry || 'Intentar de nuevo'}
    </button>
  </div>
</MainLayout>
